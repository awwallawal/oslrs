# =============================================================================
# OSLSR Environment Configuration Template
# =============================================================================
# Copy this file to .env and replace placeholder values with your actual credentials
# NEVER commit .env to version control - only .env.example is safe to commit
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL 15)
# -----------------------------------------------------------------------------
# Primary database connection
DATABASE_URL=postgres://user:password@localhost:5432/app_db

# Read replica for reporting queries (optional, can be same as primary)
DATABASE_URL_REPLICA=postgres://readonly_user:password@localhost:5432/app_db

# -----------------------------------------------------------------------------
# REDIS (Job Queue & Caching)
# -----------------------------------------------------------------------------
# Used by BullMQ for background jobs (email, imports) and caching
# Password required in production. Format: redis://:password@host:port
# Use hex passwords (openssl rand -hex 32) to avoid URL encoding issues
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379

# -----------------------------------------------------------------------------
# DOMAIN CONFIGURATION (cascading — change root vars, rest auto-derives)
# -----------------------------------------------------------------------------
# --- DOMAIN MIGRATION CHECKLIST ---
# To switch domains (e.g., oyotradeministry.com.ng → newdomain.com):
# 1. Backend: Change PUBLIC_APP_URL (verification URLs, email support URL cascade)
# 2. Frontend: Change VITE_SITE_DOMAIN (support email, public URL cascade)
# 3. CI/CD: Update VITE_API_URL GitHub repo variable (Settings → Variables → Actions)
# 4. Static: Find-replace domain in index.html + sitemap.xml + robots.txt (3 files)
# 5. Rebuild: pnpm build (frontend rebakes VITE_* vars)
# 6. VPS: Update NGINX server_name, SSL cert, restart
# 7. DNS: Point new domain A record to VPS IP
# 8. Email: Verify new domain in Resend (SPF/DKIM/DMARC)
# See docs/DOMAIN-MIGRATION.md for full runbook.
# ---

# Backend root URL (used in verification links, email support URLs)
# Development: http://localhost:5173
# Production: https://your-domain.com
PUBLIC_APP_URL=http://localhost:5173

# Backend support URL shown in email templates (optional — defaults to https://oyoskills.com)
# Separate from PUBLIC_APP_URL because app URL is localhost in dev but email links must show production domain
# SUPPORT_URL=https://yourdomain.com

# Frontend site domain (used to derive support email, public URL, meta tags)
# VITE_SITE_DOMAIN=yourdomain.com

# Frontend public URL (optional — auto-derives from VITE_SITE_DOMAIN)
# Used by site.config.ts for frontend URL construction
# VITE_PUBLIC_URL=https://yourdomain.com

# Frontend support email (optional — auto-derives from VITE_SITE_DOMAIN)
# VITE_SUPPORT_EMAIL=support@yourdomain.com

# -----------------------------------------------------------------------------
# SECURITY (JWT)
# -----------------------------------------------------------------------------
# JWT signing secrets - use strong random strings in production
# Generate with: openssl rand -base64 32
JWT_SECRET=super-secret-jwt-key-change-in-production
REFRESH_TOKEN_SECRET=super-secret-refresh-key-change-in-production

# -----------------------------------------------------------------------------
# EMAIL SERVICE
# -----------------------------------------------------------------------------
# Provider: 'resend' (production) or 'mock' (development/testing)
# Mock provider logs emails to console instead of sending
EMAIL_PROVIDER=mock

# Story 9-63 AC0 — credential isolation. In non-production (NODE_ENV != production)
# the factory REFUSES the real Resend provider even when EMAIL_PROVIDER=resend,
# falling back to mock, UNLESS you opt in here with a THROWAWAY key (never the
# prod key — that one is fingerprint-blocked regardless). Leave UNSET in dev/prod.
# ALLOW_REAL_EMAIL_IN_DEV=1
#
# Optional operator block-list: comma-separated SHA-256 hex fingerprints of keys
# that must NEVER send from non-prod (extends the committed known-prod fingerprint).
# RESEND_BLOCKED_KEY_FINGERPRINTS=

# Resend API Configuration (https://resend.com)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email sender details (must be verified domain in Resend)
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=Your App Name

# Budget Configuration
# Tier: 'free' (3K/mo, 100/day), 'pro' ($20/mo, 50K), 'scale' ($90/mo, 100K)
EMAIL_TIER=free

# Monthly overage budget in cents (Pro tier only) - $30.00 = 3000
EMAIL_MONTHLY_OVERAGE_BUDGET=3000

# Rate Limits - Max resend attempts per user per 24 hours
EMAIL_RESEND_MAX_PER_USER=3

# -----------------------------------------------------------------------------
# AWS SES (Legacy/Optional - for future use)
# -----------------------------------------------------------------------------
# AWS_SES_REGION=us-east-1
# AWS_SES_ACCESS_KEY=your-aws-access-key
# AWS_SES_SECRET_KEY=your-aws-secret-key

# -----------------------------------------------------------------------------
# DIGITALOCEAN SPACES (S3-Compatible Object Storage)
# -----------------------------------------------------------------------------
# Used for: staff photos, ID cards, bulk imports, database backups
# Setup guide: _bmad-output/developer-guides/digitalocean-spaces-setup.md

# Spaces endpoint - use your region (sfo3, nyc3, ams3, sgp1, fra1)
# Use same region as your Droplet for best performance
S3_ENDPOINT=https://sfo3.digitaloceanspaces.com
S3_REGION=sfo3

# Bucket name (create in DO console: Spaces > Create a Space)
S3_BUCKET_NAME=your-bucket-name

# Spaces access keys (DO console: API > Spaces Keys > Generate New Key)
S3_ACCESS_KEY=your-spaces-access-key-id
S3_SECRET_KEY=your-spaces-secret-key

# CDN endpoint for faster photo loading (optional but recommended)
# Enable CDN when creating Space, then use this format:
# https://{bucket}.{region}.cdn.digitaloceanspaces.com
S3_CDN_ENDPOINT=https://your-bucket-name.sfo3.cdn.digitaloceanspaces.com

# -----------------------------------------------------------------------------
# BACKUP ENCRYPTION (Story 9-9 AC#5)
# -----------------------------------------------------------------------------
# AES-256-GCM key (32 bytes / 64 hex chars) used by the daily Postgres backup
# worker to encrypt the gzipped dump BEFORE upload to DigitalOcean Spaces.
# Generate with: openssl rand -hex 32
#
# When set: backups are uploaded as `.sql.gz.enc` and the manifest gains an
#   `encryption: { algorithm, ivHex, authTagHex }` field. Restore via
#   `pnpm --filter @oslsr/api tsx scripts/restore-backup.ts --date YYYY-MM-DD`
#   (the script reads encryption metadata from the manifest automatically).
#
# When unset: backups remain unencrypted (`.sql.gz`) — backward-compat for
#   dev/test/legacy. Production MUST set this; without it, daily dumps land in
#   S3 in plaintext where any S3-credential-leak yields the entire dataset.
#
# Key management — store in THREE places:
#   1. VPS .env (single runtime source)
#   2. Operator's password manager (recovery)
#   3. Paper backup in physically secure location (last resort)
# Loss of all three = encrypted backups become unrecoverable. The runbook §6.1
# quarterly-restore-drill verifies the key still decrypts current S3 ciphertext.
BACKUP_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# GOOGLE OAUTH — RETIRED (Story 9-12 Task 10, 2026-06-09)
# -----------------------------------------------------------------------------
# Google sign-in was retired in Story 9-12 (magic-link is the public-auth channel).
# GOOGLE_CLIENT_ID / VITE_GOOGLE_CLIENT_ID removed; the GCP OAuth client was revoked
# and the GH Actions VITE_GOOGLE_CLIENT_ID variable + VPS .env entries deleted.
# Do NOT re-add — `/auth/google/verify` returns 404 GOOGLE_OAUTH_RETIRED.

# -----------------------------------------------------------------------------
# HCAPTCHA (Bot Protection)
# -----------------------------------------------------------------------------
# Get keys from: https://dashboard.hcaptcha.com
# Test keys (localhost only - always pass):
#   Site Key: 10000000-ffff-ffff-ffff-000000000001
#   Secret:   0x0000000000000000000000000000000000000000

# hCaptcha secret key (server-side verification)
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# hCaptcha site key (client-side widget) - VITE_ prefix exposes to frontend
VITE_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001

# Skip captcha validation (development only - set to false in production)
SKIP_CAPTCHA=true

# -----------------------------------------------------------------------------
# SMS SERVICE (Story 7-5 — Edit Token Delivery)
# -----------------------------------------------------------------------------
# Provider: 'mock' (default — logs to console) or 'http' (generic HTTP API)
# Mock provider stores messages in memory — suitable for dev/test
SMS_PROVIDER=mock

# HTTP provider configuration (only needed when SMS_PROVIDER=http)
# Generic endpoint — configure for any SMS vendor (Termii, Africa's Talking, etc.)
# SMS_API_URL=https://api.your-sms-vendor.com/send
# SMS_API_KEY=your-sms-api-key
# SMS_SENDER_ID=OSLRS

# -----------------------------------------------------------------------------
# ADMIN ALERTS
# -----------------------------------------------------------------------------
# Email address for system alerts and notifications
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# -----------------------------------------------------------------------------
# TELEGRAM PUSH ALERTS (Story 9-9 AC#6 — FRC item #5)
# -----------------------------------------------------------------------------
# Push-notification channel for CRITICAL system health alerts. Operator's phone
# vibrates within 1-3 seconds of a metric transitioning into CRITICAL severity
# (CPU >90%, memory >90%, disk free <10%, p95 latency >500ms, DB/Redis
# unreachable, queue waiting >200, etc.). Email digest still fires per its
# 30-min cooldown for full audit trail.
#
# Setup (5 minutes, all on operator's phone):
#   1. Telegram → search @BotFather → send /newbot → record TOKEN reply
#   2. Telegram → search @userinfobot → send /start → record CHAT_ID reply
#   3. Telegram → search your new bot (e.g., @oslsr_alerts_bot) → send /start
#      (this step is REQUIRED — Telegram won't let a bot message you until
#       you've initiated the conversation. Anti-spam protection.)
#   4. Set both env vars below; restart pm2 (`pm2 restart oslsr-api --update-env`)
#   5. Verify with curl from VPS:
#      curl -X POST "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/sendMessage" \
#        -d "chat_id=$TELEGRAM_OPERATOR_CHAT_ID" -d "text=Heartbeat from VPS"
#
# Leaving these UNSET (dev/test/local) cleanly skips the channel — no errors
# thrown. Production with both set fires push alerts on every CRITICAL.
#
# Token = "anyone-can-impersonate-the-bot" credential. Store in password manager;
# never commit. Rotate via /revoke to @BotFather if leaked.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPERATOR_CHAT_ID=

# ENABLE_TELEGRAM_ALERTS — opt-in for non-production environments (Story 9-15)
# -----------------------------------------------------------------------------
# Production (NODE_ENV=production) sends Telegram critical alerts by default;
# this var is unused there. Set to "true" ONLY in staging/preview/QA where you
# WANT critical alerts to reach the operator's phone.
#
# Local dev (NODE_ENV=development OR unset) MUST leave this empty/unset, even
# if you've copied prod TELEGRAM_BOT_TOKEN into .env for parity testing.
# Otherwise any local metric sample crossing 'critical' threshold (queue >200,
# cpu/memory >90%, p95 >500ms) will silently page the operator.
#
# Incident reference: 2026-05-11 self-page — local `pnpm dev` paged the operator
# with prod tokens because the channel was only test-mode-gated. Story 9-15
# tightened the gate to NODE_ENV=production OR ENABLE_TELEGRAM_ALERTS=true.
ENABLE_TELEGRAM_ALERTS=

# -----------------------------------------------------------------------------
# MARKETPLACE REVEAL GUARD (Story 9-41 / F-007) — all OPTIONAL, anomaly-shaped
# defaults applied when unset. Calibration is product-owned. The reveal endpoint
# stays OPEN to any registered user; these bound bulk PII exfiltration without a
# role gate. See apps/api/src/config/reveal-guard.config.ts.
# -----------------------------------------------------------------------------
# Rolling window (seconds) all volume checks are measured over. Default 86400 (24h).
REVEAL_GUARD_WINDOW_SECONDS=
# AC#2 — a profile revealed by more than this many DISTINCT viewers in-window
# blocks further NEW viewers (kills targeted harvest of one candidate). Default 5.
REVEAL_PER_PROFILE_MAX_VIEWERS=
# AC#4 — aggregate reveals across ALL viewers in-window above this trips the
# global breaker, which DEGRADES to step-up (never hard-blocks). Set well above
# legitimate aggregate, well below corpus-drain. Default 2000.
REVEAL_GLOBAL_BREAKER_MAX=
# AC#5 — per-viewer in-window volume at/above which phone-OTP / MFA step-up is
# required (progressive friction). Defaults 20 (OTP) / 40 (MFA).
REVEAL_FRICTION_OTP_THRESHOLD=
REVEAL_FRICTION_MFA_THRESHOLD=
# AC#6 — per-viewer in-window volume at/above which a stated purpose + ToS
# acceptance is required before the reveal proceeds. Default 20.
REVEAL_PURPOSE_THRESHOLD=
# AC#3 — per-device-fingerprint reveal budget, aggregated across all accounts
# sharing the fingerprint (bar-raising; the global breaker is the real backstop).
# Default 50 (matches the per-user limit).
REVEAL_DEVICE_MAX_REVEALS=

# -----------------------------------------------------------------------------
# SERVER CONFIG
# -----------------------------------------------------------------------------
# API server port
PORT=3000

# Story 9-9 AC#3 F2 (defence-in-depth): API binds to HOST:PORT. Default
# 127.0.0.1 so only nginx (on the same host) and PM2 health probes can reach
# the API directly. Override to 0.0.0.0 ONLY if you need cross-container
# reachability — production must stay 127.0.0.1 so a rogue local process or a
# container started with --network=host cannot bypass nginx. Source-code
# resolution lives in apps/api/src/lib/listen-address.ts.
HOST=127.0.0.1

# Environment: 'development', 'test', or 'production'
NODE_ENV=development
