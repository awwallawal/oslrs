#!/usr/bin/env sh
# =============================================================================
# Pre-push gate (added 2026-06-10, large-story workflow — see
# docs/large-story-workflow.md)
#
# Design rationale:
#   - pre-commit already runs `pnpm lint` + `tsc --noEmit` on every commit, so
#     any committed code is already type- and lint-clean. It does NOT run the
#     test suite (too slow per-commit).
#   - CI (.github/workflows/ci-cd.yml + e2e.yml) only fires on push to `main`
#     or PR-to-`main`. A backup push of a feature branch triggers nothing.
#
# Therefore this hook is asymmetric:
#   - Pushing to `main`  → run the FULL suite (`pnpm test`). This is the
#     belt-and-suspenders gate for a local rebase-merge → push-main, so the
#     single "coherent push" can never be a surprise CI failure.
#   - Pushing anything else (feature-branch backups, WIP) → skip the suite so
#     off-site backups stay instant. The PR's CI is the authority for those.
#
# Force the full suite on any push:  PREPUSH_FULL=1 git push ...
# Emergency bypass (use sparingly):  git push --no-verify
# =============================================================================
set -e

push_to_main=0
while read -r local_ref local_sha remote_ref remote_sha; do
  # Skip branch deletions (local_sha is all-zeros).
  case "$local_sha" in
    *[!0]*) : ;;   # has a non-zero char → a real push
    *) continue ;; # all zeros → deletion, nothing to test
  esac
  case "$remote_ref" in
    refs/heads/main) push_to_main=1 ;;
  esac
done

if [ "$push_to_main" -eq 1 ] || [ "${PREPUSH_FULL:-0}" = "1" ]; then
  echo ""
  echo "[pre-push] Push targets main (or PREPUSH_FULL=1) → running full suite (serial)"
  echo "[pre-push] (bypass for emergencies only: git push --no-verify)"
  echo ""
  # Story 9-54 (2026-06-14): run package suites SEQUENTIALLY (turbo --concurrency=1).
  # ROOT CAUSE of pre-push flakiness: plain `pnpm test` (= `turbo run test`) ran
  # api + web + utils + testing CONCURRENTLY on one machine, oversubscribing CPU
  # and the Postgres connection pool → intermittent timeout/starvation failures in
  # the real-DB integration tests (auth.activation) and heavy jsdom tests (Header).
  # Each suite is green in isolation AND in CI (which runs each package as its own
  # job on a dedicated runner — no mutual contention), so the flake was LOCAL
  # oversubscription, not the tests. --concurrency=1 gives each suite the whole
  # machine (the proven-green condition) and keeps this gate deterministic. CI is
  # unaffected (it never used turbo-all). See 9-54 "Review Follow-ups (AI)".
  #
  # Story 9-55 (2026-06-14): ALSO cap each suite's vitest worker pool. The
  # --concurrency=1 fix above serializes PACKAGES, but the web package alone
  # still spawns one worker thread per core; on this laptop — especially with a
  # second `pnpm test` running or after a sleep/resume — that oversubscribes OS
  # threads and trips "Failed to start threads worker"/timeout flakes (Pitfall
  # #37). vitest.base.ts reads VITEST_MAX_THREADS to bound the pool. CI never
  # sets it (full parallelism on dedicated runners). Override for a faster local
  # gate on an idle machine: VITEST_MAX_THREADS=4 git push
  # Story 9-58 (2026-06-15): ALSO run the production BUILD, not just test+tsc.
  # ROOT CAUSE: pre-commit runs `tsc --noEmit` and pre-push runs `vitest`, but
  # NEITHER runs `vite build`. A server-only module leaking into the web browser
  # bundle (e.g. `@oslsr/utils` barrel re-exporting crypto.ts → node:crypto) is
  # type-clean and test-clean but FAILS the vite browser build — so it sailed
  # past the local gate and only CI's `lint-and-build` caught it (red main).
  # `turbo run build` is content-hash CACHED, so this is near-instant when no
  # buildable source changed; it only rebuilds (and catches the bundle error)
  # when web/api/utils source actually changes. Build FIRST = fail fast.
  echo "[pre-push] building all packages (catches vite/browser-bundle errors tsc+vitest miss)..."
  pnpm exec turbo run build --concurrency=1
  : "${VITEST_MAX_THREADS:=2}"
  export VITEST_MAX_THREADS
  echo "[pre-push] vitest worker pool capped at VITEST_MAX_THREADS=$VITEST_MAX_THREADS"

  # Story (2026-07-03): run the suite against the CLEAN, guard-enforced test DB
  # (app_test), NOT the dev DB (app_db). Previously this gate inherited root .env
  # (DATABASE_URL=app_db, NODE_ENV=development), which made the db-guard
  # (apps/api/test/db-guard.ts) NO-OP and ran the full suite against the 499k-row
  # dev DB — polluting it with test fixtures and drifting its schema out of sync
  # (the exact failure that blocked the 2026-07-03 push). NODE_ENV=test engages
  # the guard (the DB name MUST contain "test"); app_test is provisioned by
  # `db:push:full:force` — the SAME command CI uses for its test_db (ci-cd.yml) —
  # so the local gate and CI validate an identical clean slate. dotenv.config in
  # db/index.ts does NOT override an already-exported var, so these win over root
  # .env. Override the DB with TEST_DATABASE_URL=... git push if your scratch DB
  # is named differently. Keep app_test schema current after any schema change:
  #   DATABASE_URL=postgres://user:password@localhost:5432/app_test \
  #     pnpm --filter @oslsr/api db:push:full:force
  export NODE_ENV=test
  : "${TEST_DATABASE_URL:=postgres://user:password@localhost:5432/app_test}"
  export DATABASE_URL="$TEST_DATABASE_URL"
  echo "[pre-push] tests → $DATABASE_URL (NODE_ENV=test; db-guard enforced)"

  pnpm exec turbo run test --concurrency=1
else
  echo "[pre-push] Feature-branch/backup push → skipping full suite."
  echo "[pre-push] pre-commit already gated tsc+lint; the PR's CI is the full gate."
  echo "[pre-push] Force the suite locally with: PREPUSH_FULL=1 git push"
fi
