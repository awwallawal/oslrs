    {
      "id": "modA-body",
      "type": "text",
      "x": 42,
      "y": 125,
      "width": 286,
      "height": 240,
      "text": "Duration: 2 Days (10.5 hours)\nTarget: 99 Enumerators (3 batches of 33)\n\nContent:\n• Survey walkthrough\n• Ethics & consent\n• Field protocol\n• PWA operation\n• Offline practice\n• Assessment quiz\n\nAssessment: Independent survey\n  + 20-question quiz\nPass rate: ≥80% required",
      "fontSize": 13,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
